# ─── Database ─────────────────────────────────────────────────────────────────
# Full Postgres connection string used by the server
DATABASE_URL=postgres://pfs:pfs_secret@localhost:5432/pfs

# Password used by the db service in compose (interpolated into DATABASE_URL)
PFS_DB_PASSWORD=pfs_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Web (Vite – must be prefixed VITE_) ──────────────────────────────────────
# URL the browser uses to reach the API (empty = same origin / Vite proxy)
VITE_API_URL=
